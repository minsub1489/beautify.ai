generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String          @id @default(cuid())
  title       String
  subject     String?
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  assets      Asset[]
  runs        GenerationRun[]
  messages    ProjectMessage[]
}

model Asset {
  id            String          @id @default(cuid())
  projectId     String
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind          String
  originalName  String
  mimeType      String
  size          Int
  storageKey    String
  publicUrl     String
  extractedText String?
  createdAt     DateTime        @default(now())
  outputRuns    GenerationRun[] @relation("OutputPdf")

  @@index([projectId, kind])
}

model GenerationRun {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customNotes      String?
  notionPageId     String?
  notionExtract    String?
  transcriptExtract String?
  summary          String?
  examFocusJson    Json?
  notesByPageJson  Json?
  visualsJson      Json?
  questionsJson    Json?
  outputAssetId    String?
  outputAsset      Asset?   @relation("OutputPdf", fields: [outputAssetId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([projectId, createdAt])
}

model ProjectMessage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String   @default("user")
  text      String
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

model CreditAccount {
  userId    String   @id
  balance   BigInt   @default(0)
  currency  String   @default("CREDIT")
  version   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ledgers   CreditLedger[]
}

model CreditLedger {
  id             String   @id @default(cuid())
  userId         String
  account        CreditAccount @relation(fields: [userId], references: [userId], onDelete: Cascade)
  type           String
  amount         BigInt
  balanceBefore  BigInt
  balanceAfter   BigInt
  reason         String?
  requestId      String?
  paymentOrderId String?
  idempotencyKey String   @unique
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([requestId])
}

model AiUsageRequest {
  id                 String   @id @default(cuid())
  userId             String
  status             String
  model              String
  feature            String
  inputTokens        Int      @default(0)
  outputTokens       Int      @default(0)
  fileCount          Int      @default(0)
  estimatedCost      BigInt   @default(0)
  actualCost         BigInt   @default(0)
  pricingRuleVersion String
  errorCode          String?
  metadata           Json?
  createdAt          DateTime @default(now())
  completedAt        DateTime?

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model PricingRule {
  id             String   @id @default(cuid())
  version        String   @unique
  feature        String
  model          String?
  chargeType     String
  fixedAmount    BigInt?
  inputPer1k     BigInt?
  outputPer1k    BigInt?
  fileSurcharge  BigInt   @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([feature, model, active])
}

model PaymentOrder {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerPaymentId String?
  status            String
  amountKrw         BigInt
  creditAmount      BigInt
  idempotencyKey    String   @unique
  metadata          Json?
  createdAt         DateTime @default(now())
  paidAt            DateTime?

  @@index([userId, createdAt(sort: Desc)])
  @@index([provider, providerPaymentId])
}

model PaymentWebhookEvent {
  id              String   @id @default(cuid())
  provider        String
  providerEventId String
  payload         Json
  processed       Boolean  @default(false)
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  @@unique([provider, providerEventId])
  @@index([provider, createdAt(sort: Desc)])
}

model AutoRechargeSetting {
  userId               String   @id
  enabled              Boolean  @default(false)
  threshold            BigInt   @default(1000)
  rechargeAmountKrw    BigInt   @default(10000)
  rechargeCreditAmount BigInt   @default(10000)
  paymentMethodRef     String?
  lastAttemptAt        DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
